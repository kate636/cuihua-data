# QDM BI API 凭证（必填）
QDM_ACCESS_KEY=your_access_key
QDM_SECRET_KEY=your_secret_key
QDM_API_ID=i_fjl10g687-790
QDM_HOST=https://bdapp.qdama.cn
QDM_VERSION=1.0

# MotherDuck 云数据库（留空则使用本地 DuckDB 文件）
MOTHERDUCK_TOKEN=
MOTHERDUCK_DB=fm_etl_v3

# 本地 DuckDB 路径（MOTHERDUCK_TOKEN 为空时生效）
# 生产（云端）：/opt/fm/data/fm.duckdb
FM_DUCKDB_PATH=/opt/fm/data/fm.duckdb

# ============================================================
# Query API (fm_etl_v3/query_api/) — 仅云端启用
# ============================================================

# 查询 Token 列表，格式：user1:token1,user2:token2
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(48))"
FM_TOKENS=alice:REPLACE_WITH_RANDOM_TOKEN,bob:REPLACE_WITH_RANDOM_TOKEN

# 单查询超时秒数（默认 60）
FM_QUERY_TIMEOUT_SEC=60
